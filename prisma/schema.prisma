// Enterprise AI Governance Platform – MVP Schema (Section 2.1)
// PostgreSQL. All enums defined here even if not yet used by MVP tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums (Section 2.1 – all MVP enums)
// =============================================================================

enum UserRole {
  ADMIN
  MEMBER
  VIEWER
  AUDITOR
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  ATTEST
  APPROVE
  REJECT
  LOGIN
  LOGOUT
  LOGIN_FAILED
  SET_FEATURE_FLAG
  EXPORT
  IMPORT
}

enum FeatureFlagName {
  MODULE_SHADOW_AI
  MODULE_OPS_INTEL
  MODULE_AGENTIC
  MODULE_THREAT_IR
  MODULE_ROI
  VERTICAL_HEALTHCARE
  VERTICAL_FINANCIAL
  VERTICAL_AUTOMOTIVE
}

enum Plan {
  FREE
  TEAM
  ENTERPRISE
}

enum VerticalMarket {
  GENERAL
  HEALTHCARE
  FINANCIAL
  AUTOMOTIVE
  RETAIL
  MANUFACTURING
  PUBLIC_SECTOR
}

enum DataResidency {
  EU
  US
  GLOBAL
}

enum AssetType {
  MODEL
  PROMPT
  AGENT
  DATASET
  APPLICATION
  TOOL
  PIPELINE
}

enum EuRiskLevel {
  MINIMAL
  LIMITED
  HIGH
  UNACCEPTABLE
}

enum OperatingModel {
  IN_HOUSE
  VENDOR
  HYBRID
}

enum CosaiLayer {
  LAYER_1_BUSINESS
  LAYER_2_INFORMATION
  LAYER_3_APPLICATION
  LAYER_4_PLATFORM
  LAYER_5_SUPPLY_CHAIN
}

enum AutonomyLevel {
  HUMAN_ONLY
  ASSISTED
  SEMI_AUTONOMOUS
  AUTONOMOUS
}

enum AssetStatus {
  DRAFT
  ACTIVE
  DEPRECATED
  ARCHIVED
}

enum FrameworkCode {
  NIST_AI_RMF
  EU_AI_ACT
  ISO_42001
  CUSTOM
}

enum AttestationStatus {
  PENDING
  COMPLIANT
  NON_COMPLIANT
  NOT_APPLICABLE
}

enum RiskStatus {
  IDENTIFIED
  ASSESSING
  MITIGATING
  ACCEPTED
  CLOSED
}

enum CardType {
  MODEL_CARD
  DATA_CARD
  APP_CARD
  CUSTOM
}

enum CardSource {
  REPO
  MANUAL
  API
  IMPORT
}

enum ScanType {
  SBOM
  VULN
  SECRETS
  POLICY
  LICENSE
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
  STALE
}

enum VendorType {
  MODEL_PROVIDER
  DATA_PROVIDER
  INFRASTRUCTURE
  TOOLING
  OTHER
}

enum Soc2Status {
  NOT_APPLICABLE
  IN_PROGRESS
  CERTIFIED
  EXPIRED
}

enum Iso27001Status {
  NOT_APPLICABLE
  IN_PROGRESS
  CERTIFIED
  EXPIRED
}

enum SlsaLevel {
  L0
  L1
  L2
  L3
  L4
}

// =============================================================================
// Tables
// =============================================================================

model Organization {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  plan           Plan     @default(FREE)
  verticalMarket VerticalMarket @default(GENERAL)
  dataResidency  DataResidency? @default(GLOBAL)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users              User[]
  aiAssets            AIAsset[]
  complianceFrameworks ComplianceFramework[]
  riskRegisters       RiskRegister[]
  artifactCards       ArtifactCard[]
  vendorAssurances    VendorAssurance[]
  scanRecords        ScanRecord[]
  auditLogs           AuditLog[]
  featureFlags        FeatureFlag[]
}

model User {
  id             String    @id @default(cuid())
  orgId          String
  email          String
  role           UserRole  @default(MEMBER)
  mfaEnabled     Boolean   @default(false)
  lockedUntil    DateTime?
  failedAttempts Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ownedAssets  AIAsset[]    @relation("AIAssetOwner")
  attestations ControlAttestation[]

  @@unique([orgId, email])
  @@index([orgId])
}

// AuditLog: no updatedAt. Add DB trigger in migration to prevent DELETE.
model AuditLog {
  id           String       @id @default(cuid())
  orgId        String
  userId       String
  action       AuditAction
  resourceType String
  resourceId   String
  prevState    Json?
  nextState    Json?
  ipAddress   String?
  userAgent    String?
  createdAt    DateTime     @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, createdAt])
  @@index([orgId, resourceType, resourceId])
  @@index([userId])
}

model FeatureFlag {
  id        String           @id @default(cuid())
  orgId     String
  name      FeatureFlagName
  enabled   Boolean          @default(false)
  setBy     String
  updatedAt DateTime         @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@index([orgId])
}

model AIAsset {
  id              String         @id @default(cuid())
  orgId           String
  name            String
  description     String?
  assetType       AssetType
  euRiskLevel     EuRiskLevel?
  operatingModel  OperatingModel?
  cosaiLayer      CosaiLayer?
  autonomyLevel   AutonomyLevel?
  verticalMarket  VerticalMarket?
  status          AssetStatus    @default(DRAFT)
  ownerId         String?
  deletedAt       DateTime?      // soft delete – middleware filters to deletedAt = null
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization   Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner          User?          @relation("AIAssetOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  accountabilityAssignments AccountabilityAssignment[]
  controlAttestations ControlAttestation[]
  riskRegisters  RiskRegister[]
  artifactCards  ArtifactCard[]
  scanRecords    ScanRecord[]

  @@index([orgId])
  @@index([orgId, status])
  @@index([ownerId])
}

model AccountabilityAssignment {
  id                String     @id @default(cuid())
  assetId           String
  componentName     String
  cosaiLayer        CosaiLayer
  accountableParty  String
  responsibleParty  String
  supportingParties Json?      // array of party identifiers
  notes             String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  asset AIAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, componentName, cosaiLayer])
  @@index([assetId])
  @@index([assetId, cosaiLayer])
  @@index([cosaiLayer])
}

model ComplianceFramework {
  id                      String   @id @default(cuid())
  orgId                   String
  code                    FrameworkCode
  version                 String
  name                    String
  description             String?
  verticalApplicability   Json?    // e.g. [HEALTHCARE, FINANCIAL]
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  controls     Control[]

  @@index([orgId])
}

model Control {
  id                           String   @id @default(cuid())
  frameworkId                  String
  controlId                    String   // external id within framework (e.g. AC-1)
  title                        String
  description                  String?
  cosaiLayer                   CosaiLayer?
  personaAccountable           String?
  operatingModelApplicability  Json?
  verticalApplicability        Json?
  evidenceGuidance             String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  framework     ComplianceFramework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  attestations  ControlAttestation[]

  @@unique([frameworkId, controlId])
  @@index([frameworkId])
  @@index([cosaiLayer])
}

model ControlAttestation {
  id             String            @id @default(cuid())
  controlId      String
  assetId        String
  status         AttestationStatus  @default(PENDING)
  attestedBy    String?
  attestedAt     DateTime?
  nextReviewDate DateTime?
  evidenceRef    String?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  control Control @relation(fields: [controlId], references: [id], onDelete: Cascade)
  asset   AIAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [attestedBy], references: [id], onDelete: SetNull)

  @@index([controlId])
  @@index([assetId])
  @@index([assetId, status])
}

model RiskRegister {
  id            String     @id @default(cuid())
  orgId         String
  assetId       String
  title         String
  description   String?
  likelihood    Int?       // 1–5 or similar
  impact        Int?       // 1–5 or similar
  riskScore     Float?
  residualScore Float?
  owner         String?
  cosaiLayer    CosaiLayer?
  status        RiskStatus @default(IDENTIFIED)
  deletedAt     DateTime?  // soft delete – middleware filters to deletedAt = null
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset        AIAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, status])
  @@index([assetId])
}

model ArtifactCard {
  id               String     @id @default(cuid())
  orgId            String
  assetId          String
  cardType         CardType
  sourceRepo       String?
  sourceFormat     CardSource?
  rawContent       Json?
  normalizedContent Json?
  contentHash      String?
  importedAt       DateTime   @default(now())
  lastSyncedAt     DateTime?
  syncStatus       SyncStatus @default(PENDING)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset        AIAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([assetId])
}

model VendorAssurance {
  id                String    @id @default(cuid())
  orgId             String
  vendorName        String
  vendorType        VendorType?
  cosaiLayer        CosaiLayer?
  soc2Status        Soc2Status?
  soc2ExpiresAt     DateTime?
  iso27001Status    Iso27001Status?
  slsaLevel         SlsaLevel?
  modelCardAvailable Boolean  @default(false)
  contractAligned   Boolean   @default(false)
  evidenceLinks     Json?
  lastReviewedAt    DateTime?
  nextReviewAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model ScanRecord {
  id              String    @id @default(cuid())
  orgId           String
  assetId         String
  scannerName     String
  scannerVersion  String?
  scanType        ScanType
  status          String    // e.g. RUNNING, COMPLETED, FAILED
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  findingsCount   Int       @default(0)
  criticalFindings Int     @default(0)
  findings       Json?
  policyPassed    Boolean?
  triggeredBy     String?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset        AIAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([assetId])
  @@index([assetId, scanType, completedAt])
}
