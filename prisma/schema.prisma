// AI Posture Platform – MVP Schema (Section 2.1)
// PostgreSQL. All enums defined here even if not yet used by MVP tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums (Section 2.1 – all MVP enums)
// =============================================================================

enum UserRole {
  ADMIN
  CAIO
  ANALYST
  MEMBER
  VIEWER
  AUDITOR
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  ATTEST
  APPROVE
  REJECT
  LOGIN
  LOGOUT
  LOGIN_FAILED
  SET_FEATURE_FLAG
  EXPORT
  IMPORT
}

enum FeatureFlagName {
  MODULE_SHADOW_AI
  MODULE_OPS_INTEL
  MODULE_AGENTIC
  MODULE_THREAT_IR
  MODULE_ROI
  VERTICAL_HEALTHCARE
  VERTICAL_FINANCIAL
  VERTICAL_AUTOMOTIVE
}

enum Plan {
  FREE
  TEAM
  ENTERPRISE
}

enum VerticalMarket {
  GENERAL
  HEALTHCARE
  FINANCIAL
  INSURANCE
  AUTOMOTIVE
  RETAIL
  MANUFACTURING
  PUBLIC_SECTOR
  ENERGY
}

enum DataResidency {
  EU
  US
  GLOBAL
}

enum AssetType {
  MODEL
  PROMPT
  AGENT
  DATASET
  APPLICATION
  TOOL
  PIPELINE
}

enum EuRiskLevel {
  MINIMAL
  LIMITED
  HIGH
  UNACCEPTABLE
}

enum OperatingModel {
  IN_HOUSE
  VENDOR
  HYBRID
}

enum CosaiLayer {
  LAYER_1_BUSINESS
  LAYER_2_INFORMATION
  LAYER_3_APPLICATION
  LAYER_4_PLATFORM
  LAYER_5_SUPPLY_CHAIN
}

enum AutonomyLevel {
  HUMAN_ONLY
  ASSISTED
  SEMI_AUTONOMOUS
  AUTONOMOUS
}

enum AssetStatus {
  DRAFT
  ACTIVE
  DEPRECATED
  ARCHIVED
}

enum FrameworkCode {
  NIST_AI_RMF
  EU_AI_ACT
  COSAI_SRF
  NIST_CSF
  ISO_42001
  CUSTOM
}

enum AttestationStatus {
  PENDING
  COMPLIANT
  NON_COMPLIANT
  NOT_APPLICABLE
}

enum RiskStatus {
  IDENTIFIED
  ASSESSING
  MITIGATING
  ACCEPTED
  CLOSED
}

enum CardType {
  MODEL_CARD
  DATA_CARD
  APP_CARD
  PROMPT_TEMPLATE
  DATASET_CARD
  CUSTOM
}

enum CardSource {
  REPO
  MANUAL
  API
  IMPORT
}

enum ScanType {
  SBOM
  SBOM_DEPENDENCY
  VULN
  SECRETS
  POLICY
  LICENSE
  MODEL_SCAN
  DATASET_PII
  RED_TEAM
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
  STALE
}

enum VendorType {
  MODEL_PROVIDER
  DATA_PROVIDER
  INFRASTRUCTURE
  TOOLING
  OTHER
}

enum Soc2Status {
  NOT_APPLICABLE
  IN_PROGRESS
  CERTIFIED
  EXPIRED
}

enum Iso27001Status {
  NOT_APPLICABLE
  IN_PROGRESS
  CERTIFIED
  EXPIRED
}

enum SlsaLevel {
  L0
  L1
  L2
  L3
  L4
}

enum MasterDataEntityType {
  CUSTOMER
  PRODUCT
  VENDOR
  EMPLOYEE
  FINANCE
  LOCATION
  OTHER
}

enum DataClassification {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  RESTRICTED
}

enum AiAccessPolicy {
  OPEN       // any AI system can access
  GOVERNED   // access with controls and logging
  RESTRICTED // approved AI systems only
  PROHIBITED // no AI access permitted
}

// =============================================================================
// Tables
// =============================================================================

model Organization {
  id                 String    @id @default(cuid())
  name               String
  slug               String    @unique
  plan               Plan      @default(FREE)
  tier               String    @default("FREE") // FREE, PRO, ENTERPRISE, CONSULTANT
  trialStartedAt     DateTime?
  trialEndsAt        DateTime?
  assetLimit         Int       @default(10)
  usersLimit         Int       @default(3)
  verticalMarket     VerticalMarket @default(GENERAL)
  clientVerticals    Json?     // array of vertical codes the org serves
  dataResidency      DataResidency? @default(GLOBAL)
  claimedDomain      String?   @unique
  autoJoinRole       UserRole  @default(VIEWER)
  maturityLevel      Int       @default(1)
  onboardingComplete Boolean  @default(false)
  onboardingStep     Int       @default(0)  // 0=not started, 1-5=in progress, 6=complete
  operatingModel     String?   // IAAS | PAAS | AGENT_PAAS | SAAS | MIXED
  orgSize            String?   // SMALL | MEDIUM | LARGE | ENTERPRISE
  primaryUseCase     String?   // free text, e.g. "Customer service chatbot"
  notificationsEnabled Boolean @default(true) // org-level kill switch for all emails
  createdAt          DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  consultantWorkspaces  ConsultantWorkspace[] @relation("ConsultantWorkspaces")
  clientWorkspaces     ConsultantWorkspace[]  @relation("ClientWorkspaces")
  isClientOrg          Boolean                 @default(false)
  createdByConsultantOrgId String?
  users                User[]
  pendingInvites       PendingInvite[]
  aiAssets             AIAsset[]
  complianceFrameworks ComplianceFramework[]
  riskRegisters        RiskRegister[]
  assessments          Assessment[]
  artifactCards        ArtifactCard[]
  vendorAssurances     VendorAssurance[]
  scanRecords          ScanRecord[]
  auditLogs            AuditLog[]
  featureFlags         FeatureFlag[]
  sessions             Session[]
  securityEvents       SecurityEvent[]
  accessReviews        AccessReview[]
  maturityAssessments  MaturityAssessment[]
  masterDataEntities   MasterDataEntity[]
  dataLineageRecords   DataLineageRecord[]
  dataGovernancePolicies DataGovernancePolicy[]
  regulationDiscoveries  RegulationDiscovery[]
  complianceSnapshots   ComplianceSnapshot[]
  provenanceRecords    ProvenanceRecord[]
  isoReadiness         IsoReadiness[]
  notificationLogs     NotificationLog[]
  notificationPreferences NotificationPreference[]
}

model MasterDataEntity {
  id              String               @id @default(cuid())
  orgId           String
  entityType      MasterDataEntityType
  name            String
  description     String?
  stewardId       String?              // userId of data steward
  classification  DataClassification   @default(INTERNAL)
  qualityScore    Float?              // 0-100
  recordCount     Int?
  sourceSystem    String?
  aiAccessPolicy  AiAccessPolicy       @default(RESTRICTED)
  lastReviewed    DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  organization    Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  steward         User?               @relation("DataSteward", fields: [stewardId], references: [id], onDelete: SetNull)
  lineageRecords  DataLineageRecord[] @relation("LineageSource")

  @@index([orgId])
  @@index([stewardId])
}

model DataLineageRecord {
  id                 String             @id @default(cuid())
  orgId              String
  name               String
  description        String?
  sourceEntityId    String?            // MasterDataEntity
  targetAssetId     String?            // AIAsset - which AI system uses this data
  pipelineType      String             // ETL, API, STREAM, BATCH, MANUAL
  transformations   String?           // description of transformations
  refreshFrequency  String?            // REALTIME, HOURLY, DAILY, WEEKLY, MONTHLY
  dataClassification DataClassification @default(INTERNAL)
  ownerId           String?            // userId
  lastRun           DateTime?
  status            String             @default("ACTIVE")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  organization  Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sourceEntity  MasterDataEntity?   @relation("LineageSource", fields: [sourceEntityId], references: [id], onDelete: SetNull)
  targetAsset  AIAsset?            @relation(fields: [targetAssetId], references: [id], onDelete: SetNull)
  owner        User?                @relation("LineageOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([sourceEntityId])
  @@index([targetAssetId])
}

model DataGovernancePolicy {
  id          String   @id @default(cuid())
  orgId       String
  name        String
  policyType  String   // CLASSIFICATION, RETENTION, ACCESS, QUALITY, PRIVACY
  description String
  appliesTo   DataClassification[] // classifications this policy applies to
  controls    String[]             // list of required controls
  ownerId     String?
  status      String   @default("DRAFT")
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner        User?        @relation("PolicyOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([orgId])
}

model RegulationDiscovery {
  id        String   @id @default(cuid())
  orgId     String
  assetId   String?  // optional: linked asset when reviewing existing
  inputs    Json     // wizard inputs
  results   Json     // RegulationDiscoveryResult
  createdBy String?
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset        AIAsset?     @relation(fields: [assetId], references: [id], onDelete: SetNull)
  user         User?        @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([orgId, createdAt])
}

model MaturityAssessment {
  id             String   @id @default(cuid())
  orgId          String
  assessedBy     String
  scores         Json     // { L1, L2, L3, L4, L5, overall } each 1-5
  answers        Json     // array of { questionId, answer, score }
  maturityLevel  Int      // 1-5 overall
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [assessedBy], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, createdAt])
}

model User {
  id                      String    @id @default(cuid())
  orgId                   String
  email                   String
  role                    UserRole  @default(MEMBER)
  persona                 String?   // CEO | CFO | COO | CISO | LEGAL | CAIO | DATA_OWNER | DEV_LEAD | PLATFORM_ENG | VENDOR_MGR
  personaModalDismissedAt DateTime? // when user skipped "What's your role?" modal
  mfaEnabled              Boolean   @default(false)
  lockedUntil    DateTime?
  failedAttempts Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization        Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ownedAssets         AIAsset[]           @relation("AIAssetOwner")
  stewardedEntities   MasterDataEntity[]   @relation("DataSteward")
  lineageRecordsOwned DataLineageRecord[]  @relation("LineageOwner")
  dataGovernancePoliciesOwned DataGovernancePolicy[] @relation("PolicyOwner")
  attestations        ControlAttestation[]
  sessions            Session[]
  maturityAssessments MaturityAssessment[]
  regulationDiscoveries RegulationDiscovery[]
  complianceSnapshots  ComplianceSnapshot[]
  notificationPreference NotificationPreference?

  @@unique([orgId, email])
  @@index([orgId])
}

model NotificationPreference {
  id               String   @id @default(cuid())
  userId           String   @unique
  orgId            String

  // Weekly digest
  weeklyDigest     Boolean  @default(true)
  weeklyDigestDay  String   @default("MONDAY")
  weeklyDigestTime String   @default("08:00")

  // Threshold alerts
  complianceDropAlert    Boolean @default(true)
  complianceDropThreshold Int    @default(10)
  newCriticalRiskAlert   Boolean @default(true)

  // Deadline reminders
  regulatoryDeadline90   Boolean @default(true)
  regulatoryDeadline30   Boolean @default(true)
  regulatoryDeadline7    Boolean @default(true)

  // Evidence alerts
  vendorEvidenceExpiry   Boolean @default(true)
  evidenceExpiryDays     Int     @default(30)

  // Operational alerts
  shadowAiDetected       Boolean @default(true)
  newUnownedHighRisk     Boolean @default(true)
  failedScanAlert        Boolean @default(false)

  // Delivery
  emailEnabled     Boolean  @default(true)
  slackWebhookUrl  String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model NotificationLog {
  id               String   @id @default(cuid())
  orgId            String
  userId           String?
  type             String   // WEEKLY_DIGEST, THRESHOLD_ALERT, etc
  subject          String
  sentAt           DateTime @default(now())
  status           String   @default("SENT")
  metadata         Json?

  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, sentAt])
}

model ComplianceSnapshot {
  id                   String   @id @default(cuid())
  orgId                String
  createdAt            DateTime @default(now())
  createdBy            String?
  snapshotType         String   // MANUAL, SCHEDULED, PRE_AUDIT
  frameworkCode        String? // EU_AI_ACT, NIST_AI_RMF, ISO_42001, etc.
  overallScore         Float
  layerScores          Json    // { L1, L2, L3, L4, L5 } scores
  assetCount           Int
  controlsCompliant    Int
  controlsTotal        Int
  gapCount             Int
  evidenceCompleteness Float
  notes                String?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator       User?        @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([orgId, createdAt])
}

model PendingInvite {
  id        String   @id @default(cuid())
  orgId     String
  email     String
  role      UserRole
  invitedBy String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([email])
  @@index([token])
}

// AuditLog: no updatedAt. Add DB trigger in migration to prevent DELETE.
model AuditLog {
  id           String       @id @default(cuid())
  orgId        String
  userId       String
  action       AuditAction
  resourceType String
  resourceId   String
  prevState    Json?
  nextState    Json?
  ipAddress   String?
  userAgent    String?
  createdAt    DateTime     @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, createdAt])
  @@index([orgId, resourceType, resourceId])
  @@index([userId])
}

model FeatureFlag {
  id        String           @id @default(cuid())
  orgId     String
  name      FeatureFlagName
  enabled   Boolean          @default(false)
  setBy     String
  updatedAt DateTime         @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@index([orgId])
}

model AIAsset {
  id                    String         @id @default(cuid())
  orgId                 String
  name                  String
  description           String?
  assetType             AssetType
  euRiskLevel           EuRiskLevel?
  operatingModel        OperatingModel?
  cosaiLayer            CosaiLayer?
  autonomyLevel         AutonomyLevel?
  verticalMarket        VerticalMarket?
  clientVertical        String?        // vertical this asset serves (e.g. FINANCIAL_SERVICES, HR_SERVICES)
  status                AssetStatus    @default(DRAFT)
  ownerId               String?
  overrideTier          String?        // T1/T2/T3/T4/T5
  toolAuthorizations    String[]       @default([]) // list of authorized tools/APIs
  lifecycleStage        String         @default("DEVELOPMENT") // DEVELOPMENT/TESTING/STAGING/PRODUCTION/DEPRECATED/RETIRED
  lifecycleUpdatedAt    DateTime?
  lifecycleUpdatedBy    String?        // userId
  humanOversightRequired Boolean       @default(false)
  oversightPolicy       String?        // description of oversight mechanism
  deletedAt             DateTime?      // soft delete – middleware filters to deletedAt = null
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  organization   Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner          User?          @relation("AIAssetOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  accountabilityAssignments AccountabilityAssignment[]
  controlAttestations ControlAttestation[]
  riskRegisters  RiskRegister[]
  assessments   Assessment[]
  artifactCards  ArtifactCard[]
  scanRecords    ScanRecord[]
  lineageRecords DataLineageRecord[]
  regulationDiscoveries RegulationDiscovery[]
  lifecycleTransitions  AssetLifecycleTransition[]

  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, lifecycleStage])
  @@index([ownerId])
}

model AssetLifecycleTransition {
  id          String   @id @default(cuid())
  assetId     String
  fromStage   String
  toStage     String
  direction   String   // PROMOTE | DEMOTE
  userId      String?
  notes       String?
  createdAt   DateTime @default(now())

  asset AIAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
}

model AccountabilityAssignment {
  id                String     @id @default(cuid())
  assetId           String
  componentName     String
  cosaiLayer        CosaiLayer
  accountableParty  String
  responsibleParty  String
  supportingParties Json?      // array of party identifiers
  notes             String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  asset AIAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, componentName, cosaiLayer])
  @@index([assetId])
  @@index([assetId, cosaiLayer])
  @@index([cosaiLayer])
}

model ComplianceFramework {
  id                      String   @id @default(cuid())
  orgId                   String
  code                    FrameworkCode
  version                 String
  name                    String
  description             String?
  verticalApplicability   Json?    // e.g. [HEALTHCARE, FINANCIAL]
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  controls     Control[]

  @@unique([orgId, code])
  @@index([orgId])
}

model Control {
  id                           String   @id @default(cuid())
  frameworkId                  String
  controlId                    String   // external id within framework (e.g. AC-1)
  title                        String
  description                  String?
  category                     String?
  cosaiLayer                   CosaiLayer?
  personaAccountable           String?
  operatingModelApplicability  Json?
  verticalApplicability        Json?
  implementationGuidance       String?
  evidenceGuidance             String?
  crossFrameworkIds            Json?    // array of external control IDs
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  framework     ComplianceFramework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  attestations  ControlAttestation[]

  @@unique([frameworkId, controlId])
  @@index([frameworkId])
  @@index([cosaiLayer])
}

model ControlAttestation {
  id             String            @id @default(cuid())
  controlId      String
  assetId        String
  status         AttestationStatus  @default(PENDING)
  attestedBy    String?
  attestedAt     DateTime?
  nextReviewDate DateTime?
  evidenceRef    String?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  control Control @relation(fields: [controlId], references: [id], onDelete: Cascade)
  asset   AIAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [attestedBy], references: [id], onDelete: SetNull)

  @@index([controlId])
  @@index([assetId])
  @@index([assetId, status])
}

model RiskRegister {
  id            String     @id @default(cuid())
  orgId         String
  assetId       String
  title         String
  description   String?
  likelihood    Int?       // 1–5 or similar
  impact        Int?       // 1–5 or similar
  riskScore     Float?
  residualScore Float?
  owner         String?
  cosaiLayer    CosaiLayer?
  status        RiskStatus @default(IDENTIFIED)
  deletedAt     DateTime?  // soft delete – middleware filters to deletedAt = null
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset        AIAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, status])
  @@index([assetId])
}

enum AssessmentStatus {
  DRAFT
  IN_PROGRESS
  PENDING_REVIEW
  APPROVED
}

model Assessment {
  id             String           @id @default(cuid())
  orgId          String
  name           String
  assetId        String
  status         AssessmentStatus @default(DRAFT)
  frameworkIds   Json             // array of framework IDs
  layersInScope  Json             // array of CosaiLayer
  reviewers      Json?            // { [cosaiLayer]: userId }
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset        AIAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([assetId])
  @@index([status])
}

model ArtifactCard {
  id               String     @id @default(cuid())
  orgId            String
  assetId          String
  cardType         CardType
  sourceRepo       String?
  sourceFormat     CardSource?
  rawContent       Json?
  normalizedContent Json?
  contentHash      String?
  importedAt       DateTime   @default(now())
  lastSyncedAt     DateTime?
  syncStatus       SyncStatus @default(PENDING)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset        AIAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([assetId])
}

model VendorAssurance {
  id                String    @id @default(cuid())
  orgId             String
  vendorName        String
  vendorType        VendorType?
  cosaiLayer        CosaiLayer?
  soc2Status        Soc2Status?
  soc2ExpiresAt     DateTime?
  iso27001Status    Iso27001Status?
  slsaLevel         SlsaLevel?
  modelCardAvailable Boolean  @default(false)
  contractAligned   Boolean   @default(false)
  evidenceLinks     Json?
  lastReviewedAt    DateTime?
  nextReviewAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  provenanceRecords ProvenanceRecord[]

  @@index([orgId])
}

model ProvenanceRecord {
  id                 String    @id @default(cuid())
  orgId              String
  vendorId           String
  modelName          String
  stepType           String    // TRAINING_DATA, BASE_MODEL, FINE_TUNING, DEPLOYMENT
  description        String?
  responsibleParty   String?
  attestation        Boolean   @default(false)
  attestationDetails String?
  occurredAt         DateTime?
  createdAt          DateTime  @default(now())

  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vendor       VendorAssurance @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([vendorId])
}

model ScanRecord {
  id              String    @id @default(cuid())
  orgId           String
  assetId         String
  scannerName     String
  scannerVersion  String?
  scanType        ScanType
  status          String    // e.g. RUNNING, COMPLETED, FAILED
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  findingsCount   Int       @default(0)
  criticalFindings Int     @default(0)
  findings       Json?
  policyPassed    Boolean?
  triggeredBy     String?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset        AIAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([assetId])
  @@index([assetId, scanType, completedAt])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  orgId        String
  sessionToken String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orgId])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  orgId     String
  userId    String?
  email     String?
  eventType String   // e.g. LOGIN_FAILED, BRUTE_FORCE_DETECTED
  ipAddress String?
  metadata  Json?
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, createdAt])
  @@index([email])
}

enum AccessReviewStatus {
  PENDING
  APPROVED
  REVOKED
}

model AccessReview {
  id         String            @id @default(cuid())
  orgId      String
  userId     String
  role       UserRole
  reviewDueAt DateTime
  status     AccessReviewStatus @default(PENDING)
  reviewedAt DateTime?
  reviewedBy String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, status])
  @@index([reviewDueAt])
}

model IsoReadiness {
  id          String    @id @default(cuid())
  orgId       String
  clauseId    String    // e.g. "4.1", "5.2"
  status      String    @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | COMPLETE
  notes       String?
  completedAt DateTime?
  completedBy String?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, clauseId])
  @@index([orgId])
}

model ConsultantWorkspace {
  id               String   @id @default(cuid())
  consultantOrgId  String
  clientOrgId      String
  clientName       String
  clientContact    String?
  clientVertical   String?
  assessmentScope  String   @default("FULL")
  status           String   @default("ACTIVE")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  consultantOrg Organization @relation("ConsultantWorkspaces", fields: [consultantOrgId], references: [id], onDelete: Cascade)
  clientOrg     Organization @relation("ClientWorkspaces", fields: [clientOrgId], references: [id], onDelete: Cascade)

  @@unique([consultantOrgId, clientOrgId])
  @@index([consultantOrgId])
  @@index([clientOrgId])
}
