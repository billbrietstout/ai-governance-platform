# =============================================================================
# AI Posture Platform – environment variables
# Copy to .env and fill in values. All server-side vars are validated via @t3-oss/env-nextjs.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# -----------------------------------------------------------------------------
# NextAuth v5 (Auth.js)
# -----------------------------------------------------------------------------
# Required. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-strong-secret"
# Optional. Set in production, e.g. https://your-domain.com
AUTH_URL="http://localhost:3000"
# Railway / some hosts set NEXTAUTH_URL instead — both are read by @/env
# NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Auth0 (NextAuth provider)
# -----------------------------------------------------------------------------
AUTH0_CLIENT_ID="your-auth0-client-id"
AUTH0_CLIENT_SECRET="your-auth0-client-secret"
AUTH0_ISSUER="https://YOUR_AUTH0_DOMAIN/"
# Optional if AUTH0_ISSUER is set — host only, e.g. dev-abc.us.auth0.com (Railway often adds this name)
# AUTH0_DOMAIN="YOUR_AUTH0_DOMAIN"

# Auth0 Management API (for MFA metadata sync – optional)
# Create a Machine-to-Machine app in Auth0 with Management API access.
# Required permissions: read:users, update:users, read:users_app_metadata, update:users_app_metadata
# AUTH0_MGMT_CLIENT_ID="your-mgmt-client-id"
# AUTH0_MGMT_CLIENT_SECRET="your-mgmt-client-secret"

# -----------------------------------------------------------------------------
# Sentry
# -----------------------------------------------------------------------------
# DSN for server-side error reporting (optional)
SENTRY_DSN=""
# Public DSN for client-side (optional)
NEXT_PUBLIC_SENTRY_DSN=""
# Auth token for source map uploads / CI (optional)
SENTRY_AUTH_TOKEN=""

# -----------------------------------------------------------------------------
# OpenTelemetry
# -----------------------------------------------------------------------------
OTEL_SERVICE_NAME="ai-governance-platform"
# Optional: collector endpoint
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"

# -----------------------------------------------------------------------------
# Email notifications (Resend)
# -----------------------------------------------------------------------------
# Sign up at resend.com. Free tier: 3,000 emails/month, 100/day.
# Add RESEND_API_KEY to the Railway service Variables, then redeploy.
# RESEND_API_KEY="re_your_key_here"
# Optional. If unset, sends use Resend's test sender (no domain needed):
# RESEND_FROM_EMAIL="AI Governance Platform <onboarding@resend.dev>"
# Production: verify your domain in Resend, then e.g. RESEND_FROM_EMAIL="Your App <mail@yourdomain.com>"

# -----------------------------------------------------------------------------
# Cron jobs (for scheduled digest and alerts)
# -----------------------------------------------------------------------------
# Secret for authenticating cron requests (min 16 chars). Set in Railway / cron-job.org.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRON_SECRET="generate-a-random-32-char-string-here"

# -----------------------------------------------------------------------------
# Scan webhook (external scanners push results)
# -----------------------------------------------------------------------------
# API key for POST /api/v1/scans. Required for webhook auth.
# SCAN_WEBHOOK_API_KEY="your-secret-api-key"

# -----------------------------------------------------------------------------
# Upstash Redis (rate limiting)
# -----------------------------------------------------------------------------
# Optional. Create a free Redis database at upstash.com for production rate limiting.
# UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-token"

# -----------------------------------------------------------------------------
# Application (optional overrides)
# -----------------------------------------------------------------------------
# NODE_ENV=development
